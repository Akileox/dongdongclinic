+}
+.value {
+  margin: 0;
+  font-size: 56px;
+  font-weight: 800;
+  line-height: 1;
+}
+.value span {
+  font-size: 22px;
+  margin-left: 3px;
+  color: #d7e7ff;
+  font-weight: 700;
+}
+.kpi-support {
+  margin: 0;
+  text-align: center;
+  color: #d5def5;
+  font-size: 15px;
+}
+
+.lesson {
+  padding: 22px 24px;
+  display: grid;
+  grid-template-rows: auto 1fr;
+  min-height: 0;
+}
+.lesson h2 { margin: 0 0 10px; font-size: 27px; }
+.lesson article {
+  margin: 0;
+  white-space: pre-wrap;
+  line-height: 1.67;
+  font-size: 20px;
+  color: #eff4ff;
+}
+
+.bottom-notes {
+  padding: 14px 18px;
+  display: grid;
+  gap: 10px;
+}
+.note-item h3 { margin: 0 0 3px; font-size: 15px; color: #cfdef8; }
+.note-item p { margin: 0; color: #dde6fa; font-size: 15px; line-height: 1.45; }
+
+footer {
+  text-align: center;
+  font-size: 14px;
+  color: rgba(227, 236, 255, 0.78);
+  letter-spacing: 0.2px;
+}
