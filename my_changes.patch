index 0000000000000000000000000000000000000000..aaff7a255310316b2cb9bc1384a156f056ad51ed
--- /dev/null
+++ b/templates/report.html
@@ -0,0 +1,154 @@
+<!doctype html>
+<html lang="ko">
+<head>
+  <meta charset="UTF-8" />
+  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
+  <title>TeamDJ 학생 학습 리포트</title>
+  <link rel="stylesheet" href="../static/style.css" />
+</head>
+<body>
+  <div id="report-frame" style="--canvas-w: {{ canvas_width }}px; --canvas-h: {{ canvas_height }}px;">
+    <main id="report-canvas">
+      <section class="hero glass-card">
+        <div class="brand-row">
+          <div>
+            <div class="brand">TeamDJ</div>
+            <p class="brand-sub">학생 학습 리포트</p>
