+  <script>
+    function polarToCartesian(cx, cy, r, angleDeg) {
+      const rad = (angleDeg - 90) * Math.PI / 180;
+      return { x: cx + (r * Math.cos(rad)), y: cy + (r * Math.sin(rad)) };
+    }
+
+    function arcPath(cx, cy, r, startAngle, endAngle) {
+      const start = polarToCartesian(cx, cy, r, endAngle);
+      const end = polarToCartesian(cx, cy, r, startAngle);
+      const largeArcFlag = endAngle - startAngle <= 180 ? '0' : '1';
+      return `M ${start.x} ${start.y} A ${r} ${r} 0 ${largeArcFlag} 0 ${end.x} ${end.y}`;
+    }
+
+    function drawGauge(card) {
+      const value = Math.max(0, Math.min(100, Number(card.dataset.progress || 0)));
+      const startAngle = 210;
+      const totalSweep = 300;
+      const endTrack = startAngle + totalSweep;
+      const endProgress = startAngle + (totalSweep * (value / 100));
+
+      const svg = card.querySelector('svg');
+      const track = svg.querySelector('.arc-track');
+      const progress = svg.querySelector('.arc-progress');
+
+      track.setAttribute('d', arcPath(160, 160, 112, startAngle, endTrack));
+      progress.setAttribute('d', arcPath(160, 160, 112, startAngle, endProgress));
+    }
+
+    document.querySelectorAll('.gauge-wrap').forEach(drawGauge);
+  </script>
