+# TeamDJ 다크 프리미엄 학습 리포트 생성기
+
+Jinja2 템플릿 + HTML/CSS(다크 글래스모피즘) + Playwright 스크린샷으로 **고정 프레임(1080x1560)** 학습 리포트 PNG를 생성합니다.
+
+## 파일 구조
+
+```text
+.
+├── app.py
+├── requirements.txt
+├── templates/
+│   └── report.html
+├── static/
+│   └── style.css
+└── output/
+    └── report_sample_dark.png
+```
+
+## 설치
+
+```bash
+python3 -m venv .venv
+source .venv/bin/activate
+pip install -r requirements.txt
+python -m playwright install chromium
+```
+
+## 실행
+
+```bash
+python app.py
+```
+
+실행 결과:
+
+- `output/report_sample_dark.png`
+
+## 구현 요약
+
+- `normalize_report_data()`에서 표시용 값을 정규화
+  - 테스트 미실시: `미실시`
+  - 테스트 미응시: `미응시`
+  - 평균/결석사유/특이사항/공지 기본값 처리
+- KPI는 SVG arc gauge(트랙 + 네온 그라디언트 progress + glow + 라운드 캡)로 렌더링
+- 출결과 무관하게 `이번 시간 학습 내용` 블록은 항상 렌더링
+- 다크 그라디언트 배경 + 유리 질감 카드 + 고정 레이아웃으로 메시징 공유용 시트 스타일 구성
+
+## Excel 기반 배치 생성으로 확장
+
+현재는 `SAMPLE_DATA`를 사용합니다. Excel 배치 생성 시 아래 흐름으로 확장하면 됩니다.
+
+1. Excel 각 행을 dict로 로딩
+2. `build_context(row)` 호출
+3. `render_html(context)` 후 `render_png(..., output_path)` 반복 호출
+
+예시 스켈레톤:
+
+```python
+for row in rows_from_excel:
+    context = build_context(row)
+    html = render_html(context)
+    render_png(html, Path("output") / f"{row['student_name']}_{row['date']}.png")
+```
diff --git a/app.py b/app.py
new file mode 100644
index 0000000000000000000000000000000000000000..f300b7172a801f394c6b84ad6d0fd52a93b9a1bd
--- /dev/null
+++ b/app.py
@@ -0,0 +1,136 @@
+from pathlib import Path
+from typing import Any, Dict
+
+from jinja2 import Environment, FileSystemLoader, select_autoescape
+from playwright.sync_api import sync_playwright
+
+BASE_DIR = Path(__file__).parent
+TEMPLATE_DIR = BASE_DIR / "templates"
+OUTPUT_DIR = BASE_DIR / "output"
+OUTPUT_PATH = OUTPUT_DIR / "report_sample_dark.png"
+
+CANVAS_WIDTH = 1080
+CANVAS_HEIGHT = 1560
+
+SAMPLE_DATA: Dict[str, Any] = {
+    "date": "2025.03.06",
+    "student_name": "류연진",
+    "school": "경북여고",
+    "grade": "1",
+    "class_name": "예비고1 공통수학1",
+    "attendance": "출석",
+    "absence_reason": "",
+    "test_taken": True,
+    "test_score": 84,
+    "class_average": 78,
+    "homework_completion": 68,
+    "homework_status": "부분 완료",
+    "next_homework": "합성함수와 역함수 단원, 난이도 4까지의 문제를 풀어오는 것입니다.",
+    "lesson_content": "당일 진도 합성함수와 역함수 단원 진행하였습니다.\n\n1. 합성함수\n- [기본] 표현(정의), 성립 조건\n- [기본] 합성 순서 교환 불가, 결합 가능\n- [심화] 합성함수의 개수\n- [심화] 합성함수와 방정식\n\n2. 역함수\n- [기본] 표현과 성립요건\n- [기본] 합성함수의 역함수\n- [심화] 항등식과 방정식 해석\n- [심화] 대칭점과 기울기 역수 관계\n\n추가 안내\n- 핵심 개념 설명 후 기본 유형과 응용 유형을 함께 다루었습니다.\n- 다음 시간 전까지 난이도 4까지의 문제를 풀이해 오면 좋습니다.",
+    "notice": "결석 학생에게도 당일 학습 내용과 영상이 동일하게 안내됩니다.",
+    "special_note": "당일 특이사항 없습니다.",
+}
+
+
+def normalize_report_data(raw: Dict[str, Any]) -> Dict[str, Any]:
+    """Normalize display values so later Excel rows can reuse same rendering flow."""
+    normalized = dict(raw)
+
+    test_taken = bool(raw.get("test_taken", False))
+    test_score = raw.get("test_score")
+
+    if not test_taken:
+        normalized["test_label"] = "미실시"
+        normalized["test_numeric"] = 0
+        normalized["test_unit"] = ""
+        normalized["test_support"] = "테스트가 진행되지 않았습니다."
+    elif test_score is None:
+        normalized["test_label"] = "미응시"
+        normalized["test_numeric"] = 0
+        normalized["test_unit"] = ""
+        normalized["test_support"] = "테스트에 응시하지 않았습니다."
+    else:
+        normalized["test_label"] = str(test_score)
+        normalized["test_numeric"] = max(0, min(100, int(test_score)))
+        normalized["test_unit"] = "점"
+        average = raw.get("class_average")
+        normalized["test_support"] = f"반 평균 {average}점" if average is not None else "반 평균 -"
+
+    completion = raw.get("homework_completion")
+    if completion is None:
+        normalized["homework_numeric"] = 0
+        normalized["homework_label"] = "-"
+    else:
+        normalized["homework_numeric"] = max(0, min(100, int(completion)))
+        normalized["homework_label"] = f"{int(completion)}%"
+
+    normalized["class_average_display"] = (
+        f"{raw['class_average']}점" if raw.get("class_average") is not None else "-"
+    )
+    normalized["absence_reason_display"] = raw.get("absence_reason") or "-"
+    normalized["special_note_display"] = raw.get("special_note") or "당일 특이사항 없습니다."
+    normalized["notice_display"] = raw.get("notice") or "별도 공지사항 없습니다."
+
+    attendance = raw.get("attendance", "")
+    normalized["attendance_badge_class"] = {
+        "출석": "is-attend",
+        "결석": "is-absent",
+        "지각": "is-late",
+        "조퇴": "is-early",
+    }.get(attendance, "")
+
+    return normalized
+
+
+def build_context(raw_data: Dict[str, Any]) -> Dict[str, Any]:
+    report = normalize_report_data(raw_data)
+    return {
+        "report": report,
+        "canvas_width": CANVAS_WIDTH,
+        "canvas_height": CANVAS_HEIGHT,
+        "test_progress": report["test_numeric"],
+        "homework_progress": report["homework_numeric"],
+    }
+
+
+def render_html(context: Dict[str, Any]) -> str:
+    env = Environment(
+        loader=FileSystemLoader(TEMPLATE_DIR),
+        autoescape=select_autoescape(["html", "xml"]),
+    )
+    template = env.get_template("report.html")
+    return template.render(**context)
+
+
+def render_png(html: str, output_path: Path) -> None:
+    output_path.parent.mkdir(parents=True, exist_ok=True)
+    html_path = BASE_DIR / "temp_report_dark.html"
+    html_path.write_text(html, encoding="utf-8")
+
+    with sync_playwright() as playwright:
+        browser = playwright.chromium.launch()
+        page = browser.new_page(
+            viewport={"width": CANVAS_WIDTH + 120, "height": CANVAS_HEIGHT + 120},
+            device_scale_factor=2,
+        )
+        page.goto(html_path.resolve().as_uri(), wait_until="domcontentloaded")
+        page.wait_for_load_state("networkidle")
+        page.wait_for_function("document.fonts && document.fonts.status === 'loaded'")
+
+        frame = page.locator("#report-frame")
+        frame.screenshot(path=str(output_path), type="png")
+        browser.close()
+
+    html_path.unlink(missing_ok=True)
+
+
+def generate_sample_report() -> Path:
+    context = build_context(SAMPLE_DATA)
+    html = render_html(context)
+    render_png(html, OUTPUT_PATH)
+    return OUTPUT_PATH
+
+
+if __name__ == "__main__":
+    output_file = generate_sample_report()
+    print(f"Generated report: {output_file}")
