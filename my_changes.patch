+:root {
+  --bg0: #05070f;
+  --bg1: #0a1021;
+  --bg2: #141b33;
+  --text-main: #f4f8ff;
+  --text-sub: #aeb8d3;
+  --line: rgba(255, 255, 255, 0.18);
+  --glass: rgba(255, 255, 255, 0.08);
+  --glass-strong: rgba(255, 255, 255, 0.12);
+}
+
+* { box-sizing: border-box; }
+
+html, body {
+  margin: 0;
+  padding: 0;
+  width: 100%;
+  min-height: 100%;
+  font-family: "Pretendard", "SUIT", "Apple SD Gothic Neo", "Noto Sans KR", "Malgun Gothic", sans-serif;
+  color: var(--text-main);
+  background:
+    radial-gradient(500px 380px at 9% 8%, rgba(107, 82, 255, 0.33), transparent 70%),
+    radial-gradient(430px 350px at 88% 18%, rgba(70, 155, 255, 0.30), transparent 70%),
+    radial-gradient(500px 420px at 50% 102%, rgba(255, 119, 199, 0.20), transparent 70%),
+    linear-gradient(150deg, var(--bg0) 0%, var(--bg1) 52%, var(--bg2) 100%);
+}
+
+#report-frame {
+  width: calc(var(--canvas-w) + 120px);
+  min-height: calc(var(--canvas-h) + 120px);
+  margin: 0 auto;
+  padding: 60px;
+  display: flex;
+  justify-content: center;
+  align-items: flex-start;
+}
+
+#report-canvas {
+  width: var(--canvas-w);
+  height: var(--canvas-h);
+  display: grid;
+  grid-template-rows: auto auto 1fr auto auto;
+  gap: 18px;
+}
+
+.glass-card {
+  background: linear-gradient(180deg, var(--glass-strong) 0%, var(--glass) 100%);
+  border: 1px solid var(--line);
+  border-radius: 24px;
+  backdrop-filter: blur(14px);
+  -webkit-backdrop-filter: blur(14px);
+  box-shadow:
+    0 26px 44px rgba(5, 8, 20, 0.45),
+    inset 0 1px 0 rgba(255, 255, 255, 0.14);
+}
+
+.hero {
+  padding: 26px 30px 22px;
+}
+
+.brand-row,
+.student-row {
+  display: flex;
+  justify-content: space-between;
+  align-items: center;
+}
+
+.brand { font-size: 32px; font-weight: 800; letter-spacing: 0.2px; }
+.brand-sub { margin: 2px 0 0; color: var(--text-sub); font-size: 15px; }
+.meta-date { font-size: 18px; color: #dbe8ff; font-weight: 600; }
+
+.student-row { margin-top: 16px; }
+.student-name { margin: 0; font-size: 31px; font-weight: 700; }
+.class-name { margin: 6px 0 0; color: var(--text-sub); font-size: 16px; }
+
+.attendance-badge {
+  padding: 9px 18px;
+  border-radius: 999px;
+  border: 1px solid rgba(255, 255, 255, 0.3);
+  background: rgba(255, 255, 255, 0.1);
+  font-size: 15px;
+  font-weight: 700;
+}
+.attendance-badge.is-attend { box-shadow: 0 0 18px rgba(70, 195, 255, 0.35); }
+.attendance-badge.is-absent { box-shadow: 0 0 18px rgba(255, 100, 120, 0.35); }
+.attendance-badge.is-late,
+.attendance-badge.is-early { box-shadow: 0 0 18px rgba(255, 187, 97, 0.35); }
+
+.meta-grid {
+  margin-top: 18px;
+  display: grid;
+  grid-template-columns: repeat(3, 1fr);
+  gap: 11px 18px;
+}
+.meta-grid div { display: grid; gap: 2px; }
+.meta-grid span { color: #9fb0d4; font-size: 13px; }
+.meta-grid strong { font-size: 16px; font-weight: 600; }
+
+.kpi-section {
+  padding: 16px 18px 18px;
+  display: grid;
+  grid-template-columns: 1fr 1fr;
+  gap: 14px;
+}
+
+.gauge-card {
+  border-radius: 20px;
+  border: 1px solid rgba(255, 255, 255, 0.14);
+  background: rgba(9, 14, 29, 0.56);
+  padding: 14px 14px 12px;
+}
+.gauge-card h2 { margin: 0; font-size: 18px; }
+
+.gauge-wrap {
+  margin-top: 8px;
+  height: 210px;
+  position: relative;
+  display: grid;
+  place-items: center;
+}
+
+.arc-gauge {
+  width: 100%;
+  height: 100%;
+}
+.arc-track,
+.arc-progress {
+  fill: none;
+  stroke-width: 16;
+  stroke-linecap: round;
+}
+.arc-track { stroke: rgba(255, 255, 255, 0.16); }
+
+.gauge-core {
+  position: absolute;
+  width: 146px;
+  height: 146px;
+  border-radius: 50%;
+  background: radial-gradient(circle at 30% 22%, rgba(255, 255, 255, 0.12), rgba(12, 17, 36, 0.88) 62%);
+  border: 1px solid rgba(255, 255, 255, 0.16);
+  box-shadow: inset 0 0 22px rgba(255, 255, 255, 0.05), 0 16px 26px rgba(0, 0, 0, 0.4);
+  display: grid;
